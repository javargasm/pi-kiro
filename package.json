{
  "name": "pi-kiro",
  "version": "0.1.4",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hongyilyu/pi-kiro.git"
  },
  "keywords": ["pi-package"],
  "pi": {
    "extensions": ["./dist/extension.js"]
  },
  "main": "./dist/extension.js",
  "types": "./dist/extension.d.ts",
  "exports": {
    ".": {
      "types": "./dist/extension.d.ts",
      "import": "./dist/extension.js"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build:js": "bun build src/extension.ts src/core.ts --outdir dist --target node --format esm --external '@mariozechner/*'",
    "build:types": "tsc -p tsconfig.build.json",
    "build": "bun run clean && bun run build:js && bun run build:types",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "bun run build"
  },
  "devDependencies": {
    "@mariozechner/pi-ai": "^0.72.1",
    "@types/bun": "latest",
    "vitest": "^2.0.0"
  },
  "peerDependencies": {
    "typescript": "^5",
    "@mariozechner/pi-ai": "*"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
